{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homi.local/schemas/machine/work-items.v1.schema.json",
  "title": "Homi Machine Work Items V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "documentType",
    "schemaRef",
    "authoritative",
    "generated",
    "updated",
    "workItems"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "homi.machine.work-items.v1"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "documentType": {
      "type": "string",
      "const": "work-items"
    },
    "schemaRef": {
      "type": "string",
      "const": "schemas/machine/work-items.v1.schema.json"
    },
    "authoritative": {
      "type": "boolean",
      "const": true
    },
    "generated": {
      "type": "boolean",
      "const": false
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "workItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status",
          "description",
          "affectedContracts",
          "requiredTests",
          "blockers",
          "doneCriteria",
          "evidenceLinks"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^work\\.[a-z0-9_.-]+$"
          },
          "status": {
            "type": "string",
            "enum": [
              "todo",
              "in_progress",
              "blocked",
              "done"
            ]
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "affectedContracts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "requiredTests": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "doneCriteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "evidenceLinks": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
