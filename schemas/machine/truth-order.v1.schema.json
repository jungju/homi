{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homi.local/schemas/machine/truth-order.v1.schema.json",
  "title": "Homi Machine Truth Order V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "documentType",
    "schemaRef",
    "authoritative",
    "generated",
    "updated",
    "orderedSources",
    "conflictRules",
    "generatedExclusionRules"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "homi.machine.truth-order.v1"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "documentType": {
      "type": "string",
      "const": "truth-order"
    },
    "schemaRef": {
      "type": "string",
      "const": "schemas/machine/truth-order.v1.schema.json"
    },
    "authoritative": {
      "type": "boolean",
      "const": true
    },
    "generated": {
      "type": "boolean",
      "const": false
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "orderedSources": {
      "type": "array",
      "minItems": 13,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "id",
          "path",
          "authoritative",
          "generated"
        ],
        "properties": {
          "rank": {
            "type": "integer",
            "minimum": 1
          },
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_./-]+$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "authoritative": {
            "type": "boolean"
          },
          "generated": {
            "type": "boolean"
          }
        }
      }
    },
    "conflictRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "resolution"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "higherSource": {
            "type": "string"
          },
          "lowerSource": {
            "type": "string"
          },
          "resolution": {
            "type": "string",
            "enum": [
              "first_source_wins",
              "prefer_higher"
            ]
          }
        }
      }
    },
    "generatedExclusionRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "paths",
          "behavior"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_.-]+$"
          },
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "behavior": {
            "type": "string",
            "const": "must_not_be_used_as_source_of_truth"
          }
        }
      }
    }
  }
}
