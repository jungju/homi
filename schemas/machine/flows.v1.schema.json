{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://homi.local/schemas/machine/flows.v1.schema.json",
  "title": "Homi Machine Flows V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "documentType",
    "schemaRef",
    "authoritative",
    "generated",
    "updated",
    "states",
    "events",
    "transitions",
    "invariants",
    "modeTransitionRules"
  ],
  "properties": {
    "id": {
      "type": "string",
      "const": "homi.machine.flows.v1"
    },
    "version": {
      "type": "string",
      "const": "v1"
    },
    "documentType": {
      "type": "string",
      "const": "flows"
    },
    "schemaRef": {
      "type": "string",
      "const": "schemas/machine/flows.v1.schema.json"
    },
    "authoritative": {
      "type": "boolean",
      "const": true
    },
    "generated": {
      "type": "boolean",
      "const": false
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "route",
          "mode"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^flow\\.state\\.[a-z0-9_.-]+$"
          },
          "route": {
            "type": "string"
          },
          "mode": {
            "type": "string",
            "enum": [
              "기본 모드",
              "받아쓰기 실행모드"
            ]
          }
        }
      }
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^flow\\.event\\.[a-z0-9_.-]+$"
          }
        }
      }
    },
    "transitions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "from",
          "event",
          "to",
          "contractRefs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^flow\\.[a-z0-9_.-]+$"
          },
          "from": {
            "type": "string"
          },
          "event": {
            "type": "string",
            "pattern": "^flow\\.event\\.[a-z0-9_.-]+$"
          },
          "to": {
            "type": "string",
            "pattern": "^flow\\.state\\.[a-z0-9_.-]+$"
          },
          "contractRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(product|ui|flow|ai|test)\\.[a-z0-9_.-]+$"
            }
          }
        }
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "statement",
          "contractRefs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^flow\\.invariant\\.[a-z0-9_.-]+$"
          },
          "statement": {
            "type": "string",
            "minLength": 1
          },
          "contractRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(product|ui|flow|ai|test)\\.[a-z0-9_.-]+$"
            }
          }
        }
      }
    },
    "modeTransitionRules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "fromMode",
          "toMode",
          "triggerEvent",
          "contractRefs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^flow\\.mode\\.[a-z0-9_.-]+$"
          },
          "fromMode": {
            "type": "string",
            "enum": [
              "기본 모드",
              "받아쓰기 실행모드"
            ]
          },
          "toMode": {
            "type": "string",
            "enum": [
              "기본 모드",
              "받아쓰기 실행모드"
            ]
          },
          "triggerEvent": {
            "type": "string",
            "pattern": "^flow\\.event\\.[a-z0-9_.-]+$"
          },
          "contractRefs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^(product|ui|flow|ai|test)\\.[a-z0-9_.-]+$"
            }
          }
        }
      }
    }
  }
}
